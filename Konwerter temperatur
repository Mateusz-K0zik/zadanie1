kierunek = input("Wybierz kierunek konwersji (c - Celsjusz na Fahrenheit, f - Fahrenheit na Celsjusz): ")
temperatura = float(input("Podaj wartość temperatury: "))
if kierunek == "c":
    wynik = temperatura * 1.8 + 32
    print(temperatura, "°C =", wynik, "°F")
elif kierunek == "f":
    wynik = (temperatura - 32) / 1.8
    print(temperatura, "°F =", wynik, "°C")
else:
    print("Błąd: wybrano niepoprawny kierunek konwersji.")
