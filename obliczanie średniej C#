using System;
class Program
{
    static void Main()
    {
        Console.Write("Podaj oceny oddzielone spacjami: ");
        string dane = Console.ReadLine();

        string[] oceny = dane.Split(' ');
        double suma = 0;

        for (int i = 0; i < oceny.Length; i++)
        {
            suma += Convert.ToDouble(oceny[i]);
        }
        double srednia = suma / oceny.Length;

        Console.WriteLine("Średnia: " + srednia.ToString("F2"));

        if (srednia >= 3.0)
        {
            Console.WriteLine("Uczeń zdał.");
        }
        else
        {
            Console.WriteLine("Uczeń nie zdał.");
        }
    }
}
